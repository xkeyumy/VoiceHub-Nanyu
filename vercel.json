{
  "buildCommand": "node scripts/deploy.js",
  "installCommand": "pnpm install --frozen-lockfile || pnpm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
